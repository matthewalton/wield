# Metrics-store credentials for the metadata push (docs/delivery.md).
# Copy to .env (gitignored — never commit real values; the repo is public),
# fill in from your Grafana Cloud stack, then load into GitHub Actions with:
#
#   gh secret set -f .env
#
# The stack's Prometheus remote_write push endpoint
PROM_REMOTE_WRITE_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
# The stack's numeric instance/user ID
PROM_REMOTE_WRITE_USERNAME=
# A glc_ access-policy token with metrics:write
PROM_REMOTE_WRITE_PASSWORD=
